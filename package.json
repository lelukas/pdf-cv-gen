{
  "name": "pdf-cv-gen",
  "version": "1.0.0",
  "description": "Gerador de currículos adaptados para vagas específicas",
  "type": "module",
  "scripts": {
    "gerar": "tsx src/index.ts",
    "gerar:pt": "tsx src/index.ts --lang pt",
    "exemplo": "tsx src/index.ts exemplo-vaga.txt",
    "lint": "eslint src/",
    "format": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.0"
  }
}
